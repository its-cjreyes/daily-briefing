# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# SendGrid (https://app.sendgrid.com)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=briefing@yourdomain.com
RECIPIENT_EMAIL=

# Vercel KV — auto-populated when you link a KV store in the Vercel dashboard
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# A random secret to protect the /api/generate route
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Your production app URL (no trailing slash)
APP_URL=https://your-app.vercel.app
